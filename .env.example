# =============================================================================
#  MAKEJA RENTALS — ENVIRONMENT VARIABLES REFERENCE
#  Copy to .env.local and fill in all values before running.
#  NEVER commit .env.local to version control.
# =============================================================================

# ─── Supabase (Required) ──────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# ─── Application (Required) ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://makeja.co.ke
NEXT_PUBLIC_APP_NAME=Makeja Rentals

# ─── Google OAuth (Required for social login) ─────────────────────────────────
# Configure at: Supabase Dashboard → Authentication → Providers → Google
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ─── Email - Resend (Required for transactional emails) ───────────────────────
# Get API key: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@makeja.co.ke
RESEND_FROM_NAME=Makeja Rentals

# ─── SMS / Africa's Talking (Optional — for SMS OTP) ─────────────────────────
AFRICASTALKING_API_KEY=your_africastalking_api_key
AFRICASTALKING_USERNAME=makeja
AFRICASTALKING_SENDER_ID=MAKEJA

# ─── M-Pesa / Daraja API (Optional — for payments) ───────────────────────────
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=174379
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=https://makeja.co.ke/api/webhooks/mpesa

# ─── Redis / Upstash (Optional — for rate limiting & caching) ─────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─── Analytics (Optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Error Monitoring / Sentry (Optional) ────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://key@sentry.io/project-id
SENTRY_ORG=makeja-rentals
SENTRY_PROJECT=nextjs

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your_32_byte_random_hex_string
CRON_SECRET=your_cron_job_secret

# ─── Storage Buckets ──────────────────────────────────────────────────────────
NEXT_PUBLIC_BUCKET_PROPERTY_IMAGES=property-images
NEXT_PUBLIC_BUCKET_AVATARS=avatars
SUPABASE_BUCKET_VERIFICATIONS=verifications
SUPABASE_BUCKET_ATTACHMENTS=message-attachments

# ─── Feature Flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_ROOMMATES=true
NEXT_PUBLIC_FEATURE_MPESA=false
NEXT_PUBLIC_FEATURE_REALTIME_CHAT=false
NEXT_PUBLIC_FEATURE_MAP_VIEW=true

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_AUTH_MAX=10
